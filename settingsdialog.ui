   <property name="styleSheet">
    <string notr="true">/* The main tab widget frame */
QTabWidget::pane {
    border: 1px solid #C0C7C9;
    background: #f9ffed;
    border-radius: 4px;
}

/* Customize the individual tabs */
QTabBar::tab {
    background: #54e81a;
    border: 1px solid #79ed4c;
    border-bottom: none; 
    border-top-left-radius: 15px;
    padding: 7px 35px;
	font-weight: bold;
	color: white;
}

/* Selected tab state */
QTabBar::tab:selected {
    background: #c2ff40;
    border-color: #99A1A5;
    border-bottom: 1px solid #FFFFFF;
}

/* Hover state for unselected tabs */
QTabBar::tab:hover {
    background: #D5DCDD;
}

QTabBar::tab {
    /* Keeps the top/bottom padding tight and expands the left/right space */
    padding: 4px 20px; 
    
    /* Optional: Sets a minimum width to prevent clipping short words */
    min-width: 80px; 
}
</string>
   </property>
